# node_modules must never be copied in: ffmpeg-static and youtube-dl-exec vendor
# *platform-specific* binaries, and the host here is Windows. Copying them would
# put ffmpeg.exe and yt-dlp.exe inside a Linux image, where ingest fails with an
# exec-format error that looks nothing like its cause. The image installs its own.
node_modules
**/node_modules

# Build output is produced inside the image.
dist
**/dist
web/dist-sw

# The media directory is the volume. Baking it into the image would both bloat
# it enormously and shadow the mount.
server/media

.git
.gitignore
.claude
*.md
Dockerfile
docker-compose.yml
.dockerignore
