{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false
  },
  // `sw.ts` is checked by tsconfig.sw.json instead: it needs the WebWorker lib,
  // which cannot coexist with DOM in one program.
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/sw.ts"],
  "references": [{ "path": "../shared" }]
}
